{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "api": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "mode": { "type": "string", "enum": ["observe", "guard"] }
      }
    },
    "cometbft": {
      "type": "object",
      "properties": {
        "replicas": { "type": "integer", "minimum": 1 },
        "validatorKeys": {
          "type": "object",
          "required": ["existingSecret"],
          "properties": {
            "existingSecret": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "ha": {
          "type": "object",
          "properties": {
            "snapshotRetentionDays": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
