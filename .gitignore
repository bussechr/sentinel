# Sentinel .gitignore

# Secrets — never commit
deploy/compose/secrets/
*.pem
*.key
*.p12
*.pfx
sentinel_postgres_dsn*

# Go build artefacts
/bin/
/dist/
*.exe

# Go modules download cache
vendor/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Policy bundle tarballs
policy/bundles/*.tar.gz

# SDK build artefacts
sdk/ts/node_modules/
sdk/ts/dist/
sdk/ts/package-lock.json
sdk/python/build/
sdk/python/dist/
sdk/python/*.egg-info/
sdk/python/.pytest_cache/
